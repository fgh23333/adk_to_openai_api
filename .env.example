# ========================================
# ADK Middleware 环境变量配置示例
# ========================================
# 复制此文件为 .env 并修改相应配置

# ==================== 基础配置 ====================
CONTAINER_NAME=adk-middleware
HOST_PORT=8000
HOST_DATA_PATH=./data
URL_PREFIX=/adk
PROJECT_NAME=adk-middleware

# ==================== ADK 后端配置 ====================
#
# 方式一：映射表（适合少量特殊配置的应用）
# ADK_BACKEND_MAPPING=special-app:http://special-backend:8080
#
# 方式二：模板（适合大量应用，自动生成地址）
# 支持占位符: {app} 或 {app_name} 会被替换为应用名
# ADK_BACKEND_TEMPLATE=http://{app}.adk.internal.local:8080
#
# 方式三：混合模式（推荐）
# 映射表优先（用于特殊应用）+ 模板兜底（用于常规应用）
# 例如: special-app 用映射表，其他用模板

# 示例1: 只用模板
# ADK_BACKEND_TEMPLATE=http://{app}.adk.internal.local:8080
# 请求: customer-service/chat_agent
# → 访问: http://customer-service.adk.internal.local:8080

# 示例2: 只用映射表
# ADK_BACKEND_MAPPING=default:http://host.docker.internal:8000,customer-service:http://adk-cs:8080

# 示例3: 混合模式（推荐）
ADK_BACKEND_MAPPING=special-app:http://special-backend:8080
ADK_BACKEND_TEMPLATE=http://{app}.adk.internal.local:8080
# 请求: special-app/chat_agent → http://special-backend:8080 (映射表优先)
# 请求: customer-service/chat_agent → http://customer-service.adk.internal.local:8080 (模板兜底)
# 请求: sales-assistant/chat_agent → http://sales-assistant.adk.internal.local:8080 (模板兜底)

# 默认应用名（当 model 字段只有 agent 名时使用）
ADK_APP_NAME=default

# ==================== 认证配置 ====================
ENABLE_API_KEY_AUTH=false
API_KEY=

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 会话历史 ====================
SESSION_HISTORY_ENABLED=true
SESSION_RETENTION_DAYS=30

# ==================== 多模态配置 ====================
MAX_FILE_SIZE_MB=20
ALLOWED_MIME_TYPES=image/*,audio/*,video/*,application/pdf
FILE_DOWNLOAD_TIMEOUT=60
MAX_CONCURRENT_DOWNLOADS=10

# ==================== 监控配置 ====================
ENABLE_METRICS=true
METRICS_RETENTION_HOURS=24

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=*
