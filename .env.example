# ========================================
# ADK Middleware 环境变量配置示例
# ========================================
# 复制此文件为 .env 并修改相应配置

# ==================== 基础配置 ====================
CONTAINER_NAME=adk-middleware
HOST_PORT=8000
HOST_DATA_PATH=./data
URL_PREFIX=/adk
PROJECT_NAME=adk-middleware

# ==================== ADK 后端配置 ====================
# 多后端映射
# 格式: app_name:backend_url,app_name2:backend_url2
# 示例: ADK_BACKEND_MAPPING=special-app:http://special-backend:8080
ADK_BACKEND_MAPPING=

# ==================== 认证配置 ====================
ENABLE_API_KEY_AUTH=false
API_KEY=

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 会话历史 ====================
SESSION_HISTORY_ENABLED=true
SESSION_RETENTION_DAYS=30

# ==================== 多模态配置 ====================
MAX_FILE_SIZE_MB=20
FILE_DOWNLOAD_TIMEOUT=60
MAX_CONCURRENT_DOWNLOADS=10

# ==================== 监控配置 ====================
ENABLE_METRICS=true
METRICS_RETENTION_HOURS=24

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=*
