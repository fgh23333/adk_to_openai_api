# ========================================
# ADK Middleware 环境变量配置示例
# ========================================
# 复制此文件为 .env 并修改相应配置

# ==================== 基础配置 ====================
CONTAINER_NAME=adk-middleware
HOST_PORT=8000
HOST_DATA_PATH=./data
URL_PREFIX=/adk
PROJECT_NAME=adk-middleware

# ==================== ADK 后端配置 ====================
# 默认后端地址（兜底）
ADK_BACKEND_URL=http://host.docker.internal:8000

# 默认应用名（当 model 字段只有 agent 名时使用）
ADK_APP_NAME=agent

# 多应用后端映射（应用名:后端地址，用逗号分隔）
# 示例1: 两个应用
# ADK_BACKEND_MAPPING=app1:http://adk-1.internal.local:8080,app2:http://adk-2.internal.local:8080

# 示例2: 三个应用（不同应用下有同名 agent）
ADK_BACKEND_MAPPING=customer-service:http://adk-cs.internal.local:8080,sales-assistant:http://adk-sales.internal.local:8080,tech-support:http://adk-tech.internal.local:8080

# 示例3: JSON 格式（适合复杂场景）
# ADK_BACKEND_MAPPING={"app1":"http://adk-1:8080","app2":"http://adk-2:8080"}

# ==================== 认证配置 ====================
ENABLE_API_KEY_AUTH=false
API_KEY=

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 会话历史 ====================
SESSION_HISTORY_ENABLED=true
SESSION_RETENTION_DAYS=30

# ==================== 多模态配置 ====================
MAX_FILE_SIZE_MB=20
ALLOWED_MIME_TYPES=image/*,audio/*,video/*,application/pdf
FILE_DOWNLOAD_TIMEOUT=60
MAX_CONCURRENT_DOWNLOADS=10

# ==================== 监控配置 ====================
ENABLE_METRICS=true
METRICS_RETENTION_HOURS=24

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=*
