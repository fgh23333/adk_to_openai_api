# ========================================
# ADK Middleware 环境变量配置示例
# ========================================
# 复制此文件为 .env 并修改相应配置

# ==================== ADK 后端配置（必填）====================
# 多后端映射，格式: app_name:backend_url,app_name2:backend_url2
# 示例: ADK_BACKEND_MAPPING=data-analysis:http://172.31.243.14:8000,app2:http://xxx:8000
ADK_BACKEND_MAPPING=

# 请求超时配置（毫秒）
ADK_TIMEOUT=120000
ADK_CONNECT_TIMEOUT=30000

# ==================== 认证配置 ====================
# 是否启用 API Key 认证
ENABLE_API_KEY_AUTH=false

# API Key（启用认证时必填）
API_KEY=

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 会话历史 ====================
SESSION_HISTORY_ENABLED=true
SESSION_RETENTION_DAYS=30

# ==================== 监控配置 ====================
ENABLE_METRICS=true
METRICS_RETENTION_HOURS=24

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=*
