# ========================================
# ADK Middleware 环境变量配置示例
# ========================================
# 复制此文件为 .env 并修改相应配置

# ==================== 基础配置 ====================
CONTAINER_NAME=adk-middleware
HOST_PORT=8000
HOST_DATA_PATH=./data
URL_PREFIX=/adk
PROJECT_NAME=adk-middleware

# ==================== ADK 后端配置 ====================
# 默认后端地址（用于获取应用列表和兜底）
ADK_HOST=http://localhost:8000

# 多后端映射（可选，用于特殊应用）
# 格式: app_name:backend_url,app_name2:backend_url2
# 示例: ADK_BACKEND_MAPPING=special-app:http://special-backend:8080
ADK_BACKEND_MAPPING=

# 默认应用名（当 model 字段只有 agent 名时使用）
ADK_APP_NAME=agent

# ==================== 认证配置 ====================
ENABLE_API_KEY_AUTH=false
API_KEY=

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 会话历史 ====================
SESSION_HISTORY_ENABLED=true
SESSION_RETENTION_DAYS=30

# ==================== 多模态配置 ====================
MAX_FILE_SIZE_MB=20
ALLOWED_MIME_TYPES=image/*,audio/*,video/*,application/pdf
FILE_DOWNLOAD_TIMEOUT=60
MAX_CONCURRENT_DOWNLOADS=10

# ==================== 监控配置 ====================
ENABLE_METRICS=true
METRICS_RETENTION_HOURS=24

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=*
